generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  createdAt DateTime @default(now())
  scores    Score[]
}

model Score {
  id        String   @id @default(cuid())
  userId    String
  game      String
  points    Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}
